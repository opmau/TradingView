//@version=5

// @description Common math helper functions for Pine Script.
library("MathUtils", overlay=false)

// @function Returns the absolute value of x.
// @param x (float) Input value.
// @returns (float) Absolute value of x.
export abs(float x) =>
    x >= 0 ? x : -x

// @function Clamps x between low and high bounds.
// @param x   (float) Value to clamp.
// @param low  (float) Lower bound.
// @param high (float) Upper bound.
// @returns (float) Clamped value.
export clamp(float x, float low, float high) =>
    math.max(low, math.min(high, x))

// @function Linear interpolation between a and b by factor t (0–1).
// @param a (float) Start value.
// @param b (float) End value.
// @param t (float) Interpolation factor (0 = a, 1 = b).
// @returns (float) Interpolated value.
export lerp(float a, float b, float t) =>
    a + (b - a) * clamp(t, 0.0, 1.0)

// @function Normalises x to the range [0, 1] given known min and max.
// @param x   (float) Value to normalise.
// @param low  (float) Minimum of the range.
// @param high (float) Maximum of the range.
// @returns (float) Normalised value in [0, 1].
export normalise(float x, float low, float high) =>
    high == low ? 0.0 : clamp((x - low) / (high - low), 0.0, 1.0)
